{
  "expo": {
    "name": "Workpulse",
    "slug": "workpulse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Blue and White Modern Medical Logo (3).png",
    "scheme": "workpulse",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff",
        "foregroundImage": "./assets/images/Blue and White Modern Medical Logo (3).png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.vipprow.workpulse"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/Blue and White Modern Medical Logo (3).png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Blue and White Modern Medical Logo (3).png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "208b0a26-5864-4f12-a8ad-42b076cdc961"
      }
    }
  }
}
